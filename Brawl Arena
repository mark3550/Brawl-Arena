/* ─── HELPERS ────────────────────────────────────────────────── */
function seededShuffle(arr, seed) {
const a = […arr];
for (let i = a.length - 1; i > 0; i–) {
const j = Math.abs((seed * 2654435761 + i * 1234567) % (i + 1));
[a[i], a[j]] = [a[j], a[i]];
}
return a;
}

function buildTournaments(maps) {
const TWO_H = 2 * 60 * 60 * 1000;
const now = Date.now();
const slot0 = Math.floor(now / TWO_H) * TWO_H;
const baseNum = Math.floor(slot0 / TWO_H) % 900 + 100;
return Array.from({ length: 6 }, (_, i) => {
const start = slot0 + i * TWO_H;
const end = start + TWO_H;
const isLive = now >= start && now < end;
const seed = Math.floor(start / TWO_H);
const tMaps = seededShuffle(maps, seed).slice(0, 5);
return {
id: seed,
number: baseNum + i,
start,
end,
isLive,
maps: tMaps,
regCount: isLive ? 12 + i : Math.max(0, 8 - i * 3),
maxTeams: 16,
glowIdx: i % GLOW.length,
};
});
}

function fmtCountdown(ms) {
if (ms <= 0) return “Startet jetzt!”;
const h = Math.floor(ms / 3600000);
const m = Math.floor((ms % 3600000) / 60000);
const s = Math.floor((ms % 60000) / 1000);
return h > 0 ? `${h}h ${m}m ${s}s` : m > 0 ? `${m}m ${s}s` : `${s}s`;
}

function fmtTime(ts) {
return new Date(ts).toLocaleTimeString(“de-DE”, { hour: “2-digit”, minute: “2-digit” });
}

