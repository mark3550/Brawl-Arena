// Fetch maps from Brawlify API
useEffect(() => {
(async () => {
try {
const res = await fetch(“https://api.brawlify.com/v1/maps”);
const data = await res.json();
const ranked = (data.list || []).filter(m =>
m.gameMode && RANKED_MODES.includes(m.gameMode.name) && !m.disabled
).map(m => ({
id: m.id,
name: m.name,
gameMode: m.gameMode.name,
imageUrl: m.imageUrl,
}));
if (ranked.length >= 8) setMaps(ranked);
} catch {
// keep fallback
}
})();
}, []);

useEffect(() => {
setTournaments(buildTournaments(maps));
}, [maps]);

// Refresh countdown every second
useEffect(() => {
const id = setInterval(() => {
setTick(t => t + 1);
setTournaments(prev => prev.map(t => ({
…t,
isLive: Date.now() >= t.start && Date.now() < t.end,
})));
}, 1000);
return () => clearInterval(id);
}, []);

const hasLive = tournaments.some(t => t.isLive);

return (
